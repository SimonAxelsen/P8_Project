FROM oven/bun:1

WORKDIR /app

COPY package.json bun.lock ./
RUN bun install --frozen-lockfile

COPY index.ts evaluator.ts elevenlabs.ts tsconfig.json ./
COPY modelfiles ./modelfiles

RUN mkdir -p /app/data

ENV PORT=3001
ENV OLLAMA_URL=http://host.docker.internal:11434/api/generate
ENV CHAT_LOG_FILE=/app/data/chat_log.jsonl
ENV ENABLE_ELEVENLABS=false

EXPOSE 3001

CMD ["bun", "run", "index.ts"]
